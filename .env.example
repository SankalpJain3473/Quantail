# .env.example
# Copy to .env and fill in your values before deploying
# NEVER commit .env to git

# ── Security ──────────────────────────────────────────────────────────────
QUANTAIL_SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ENVIRONMENT=production

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Market data ───────────────────────────────────────────────────────────
POLYGON_API_KEY=your-polygon-api-key-here

# ── Frontend build vars (baked in at docker build time) ───────────────────
VITE_API_URL=https://yourdomain.com
VITE_WS_URL=wss://yourdomain.com/ws/trading

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
